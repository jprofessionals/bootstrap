    async function saveCustomProvider() {
      const name = document.getElementById('cp-name').value.trim();
      const url = document.getElementById('cp-url').value.trim();
      const mode = document.getElementById('cp-mode').value;
      const key = document.getElementById('cp-key').value.trim();
      const statusEl = document.getElementById('cp-status');
      if (!name || !url) { statusEl.textContent = 'Name and URL required'; statusEl.style.color = '#f48771'; return; }
      statusEl.textContent = 'Saving...'; statusEl.style.color = '#808080';
      try {
        const r = await fetch(`${AI_BASE_URL}/api/ai/custom-provider`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ name, base_url: url, api_mode: mode, api_key: key || '' })
        });
        if (r.ok) {
          hideAddCustomForm();
          checkApiKeyAndShow();
        } else {
          const err = await r.json().catch(() => ({}));
          statusEl.textContent = err.error || 'Failed'; statusEl.style.color = '#f48771';
        }
      } catch (e) { statusEl.textContent = e.message; statusEl.style.color = '#f48771'; }
    }

    async function toggleCustomProvider(id, enabled) {
      await fetch(`${AI_BASE_URL}/api/ai/custom-provider/${id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ enabled })
      });
      loadModels();
    }

    async function deleteCustomProvider(id) {
      if (!confirm('Delete this custom provider?')) return;
      await fetch(`${AI_BASE_URL}/api/ai/custom-provider/${id}`, {
        method: 'DELETE', credentials: 'include'
      });
      checkApiKeyAndShow();
    }

    function toggleAiDock() {
      const panel = document.getElementById('ai-panel');
      const sidebar = document.getElementById('left-sidebar');
      const monacoContainer = document.getElementById('monaco-container');

      if (aiPanelDock === 'right') {
        aiPanelDock = 'left';
        sidebar.appendChild(panel);
        panel.classList.add('docked-left');
      } else {
        aiPanelDock = 'right';
        const gitPanel = document.getElementById('git-panel');
        if (gitPanel && gitPanel.parentElement === document.getElementById('editor-layout')) {
          gitPanel.after(panel);
        } else {
          monacoContainer.after(panel);
        }
        panel.classList.remove('docked-left');
      }
      applyLayoutClasses();
      editor.layout();
    }

    async function checkApiKeyAndShow() {
      try {
        const r = await fetch(`${AI_BASE_URL}/api/ai/apikey`, { credentials: 'include' });
        if (r.status === 401 || r.status === 403) {
          document.getElementById('ai-setup').classList.remove('hidden');
          document.getElementById('ai-key-status').textContent = 'Please log in first.';
          return;
        }
        if (!r.ok) {
          document.getElementById('ai-setup').classList.remove('hidden');
          document.getElementById('ai-key-status').textContent = 'AI service error (' + r.status + ')';
          return;
        }
        const data = await r.json();
        let hasAnyEnabled = false;

        // Render built-in provider rows with toggles
        const listEl = document.getElementById('ai-provider-list');
        listEl.innerHTML = '';
        if (data.providers) {
          const names = { anthropic: 'Anthropic', openai: 'OpenAI', gemini: 'Gemini' };
          for (const [key, status] of Object.entries(data.providers)) {
            const row = document.createElement('div');
            row.className = 'provider-row';
            const nameSpan = document.createElement('span');
            nameSpan.className = 'provider-name' + (key === selectedProvider ? ' active' : '');
            nameSpan.dataset.provider = key;
            nameSpan.textContent = (names[key] || key) + (status.configured ? ' \u2713' : '');
            nameSpan.onclick = () => selectProviderTab(key);
            const toggle = document.createElement('label');
            toggle.className = 'toggle-switch';
            toggle.innerHTML = `<input type="checkbox" ${status.enabled ? 'checked' : ''} ${!status.configured ? 'disabled' : ''} onchange="toggleProvider('${key}', this.checked)"><span class="slider"></span>`;
            row.appendChild(nameSpan);
            row.appendChild(toggle);
            listEl.appendChild(row);
            if (status.enabled) hasAnyEnabled = true;
          }
        }

        // Render custom providers
        const cpList = document.getElementById('custom-provider-list');
        cpList.innerHTML = '';
        if (data.custom && data.custom.length > 0) {
          for (const cp of data.custom) {
            const item = document.createElement('div');
            item.className = 'custom-provider-item';
            item.innerHTML = `<span class="cp-name">${cp.name}</span><span class="cp-mode">${cp.api_mode}</span><label class="toggle-switch"><input type="checkbox" ${cp.enabled ? 'checked' : ''} onchange="toggleCustomProvider(${cp.id}, this.checked)"><span class="slider"></span></label><button class="cp-btn" onclick="deleteCustomProvider(${cp.id})">\u2715</button>`;
            cpList.appendChild(item);
            if (cp.enabled) hasAnyEnabled = true;
          }
        }
        // Hide "Add" if at limit
        const addBtn = document.getElementById('add-custom-btn');
        if (addBtn) addBtn.style.display = (data.custom && data.custom.length >= 5) ? 'none' : '';

        if (hasAnyEnabled) {
          document.getElementById('ai-chat-area').classList.remove('hidden');
          document.getElementById('ai-chat-area').style.display = 'flex';
          loadModels();
        }
        document.getElementById('ai-setup').classList.remove('hidden');
      } catch (e) {
        document.getElementById('ai-setup').classList.remove('hidden');
        document.getElementById('ai-key-status').textContent = 'Cannot reach AI server';
      }
    }

    async function saveApiKey() {
      const key = document.getElementById('ai-key-input').value.trim();
      if (!key) return;
      const statusEl = document.getElementById('ai-key-status');
      statusEl.textContent = 'Saving...';
      try {
        const r = await fetch(`${AI_BASE_URL}/api/ai/apikey`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ api_key: key, provider: selectedProvider })
        });
        if (r.ok) {
          statusEl.textContent = `${selectedProvider} key saved!`;
          statusEl.style.color = '#5a5';
          document.getElementById('ai-key-input').value = '';
          checkApiKeyAndShow();
        } else {
          const err = await r.json().catch(() => ({}));
          statusEl.textContent = err.error || 'Failed to save key';
          statusEl.style.color = '#f48771';
        }
      } catch (e) {
        statusEl.textContent = 'Failed to save key: ' + e.message;
        statusEl.style.color = '#f48771';
      }
    }

    async function loadModels() {
      try {
        const r = await fetch(`${AI_BASE_URL}/api/ai/models`, { credentials: 'include' });
        if (!r.ok) return;
        const data = await r.json();
        const select = document.getElementById('ai-model-select');
        const prevValue = select.value;
        select.innerHTML = '';
        const providers = data.providers || data;
        for (const [provider, models] of Object.entries(providers)) {
          if (!models || models.length === 0) continue;
          const group = document.createElement('optgroup');
          // Custom providers: "custom:1" -> use the model name as group label
          if (provider.startsWith('custom:')) {
            group.label = models[0]?.name || provider;
          } else {
            group.label = provider.charAt(0).toUpperCase() + provider.slice(1);
          }
          for (const m of models) {
            const opt = document.createElement('option');
            opt.value = JSON.stringify({ provider, model: m.id });
            opt.textContent = m.name;
            group.appendChild(opt);
          }
          select.appendChild(group);
        }
        // Restore previous selection if still available
        if (prevValue) {
          for (const opt of select.options) {
            if (opt.value === prevValue) { select.value = prevValue; break; }
          }
        }
        if (select.options.length > 0 && !select.value) {
          select.selectedIndex = 0;
        }
        updateSelectedModel();
      } catch (e) {
        console.error('Failed to load models:', e);
      }
    }

    function updateSelectedModel() {
      const select = document.getElementById('ai-model-select');
      if (select.value) {
        const parsed = JSON.parse(select.value);
        selectedProvider = parsed.provider;
        selectedModel = parsed.model;
      }
    }

    function sendAiMessage() {
      const input = document.getElementById('ai-input');
      const text = input.value.trim();
      if (!text || aiRunning) return;

      let messageText = text;
      if (text.startsWith('/')) {
        const parts = text.match(/^\/(\S+)\s*(.*)/);
        if (parts) {
          const skillName = parts[1];
          const args = parts[2];
          const skill = allSkills.find(s => s.name === skillName);
          if (skill && skill.content) {
            messageText = `[Using skill: ${skill.name}]\n\n${skill.content}\n\n${args}`;
          }
        }
      }

      appendAiMessage('user', text);
      aiConversation.push({ role: 'user', content: messageText });
      input.value = '';

      runAgentLoop();
    }

    function stopAi() {
      aiRunning = false;
      if (aiAbortController) aiAbortController.abort();
    }

    // --- Skills Loading ---
    async function loadSkills() {
      allSkills = [];

      try {
        const r = await fetch(`${AI_BASE_URL}/api/ai/skills`, { credentials: 'include' });
        if (r.ok) {
          const skills = await r.json();
          for (const s of skills) {
            allSkills.push({ ...s, source: 'platform' });
          }
        }
      } catch (e) {}

      try {
        const { repo } = getRepoParts();
        const files = await fetch(`/api/editor/files?repo=${repo}`).then(r => r.json());
        const skillFiles = files.files.filter(f => f.path.startsWith('.skills/') && f.path.endsWith('.md'));
        for (const sf of skillFiles) {
          const name = sf.path.replace('.skills/', '').replace('.md', '');
          allSkills.push({ name, description: `Builder skill: ${name}`, source: 'builder', path: sf.path });
        }
      } catch (e) {}

      renderSkillsBar();
    }

    function renderSkillsBar() {
      const bar = document.getElementById('ai-skills-bar');
      bar.innerHTML = '';
      if (!allSkills.length) return;

      allSkills
        .filter(s => s.user_invocable !== false)
        .forEach(s => {
          const chip = document.createElement('span');
          chip.className = 'skill-chip';
          chip.textContent = s.name;
          chip.title = s.description || '';
          chip.addEventListener('click', () => insertSkillCommand(s.name));
          bar.appendChild(chip);
        });
    }

    function insertSkillCommand(name) {
      const input = document.getElementById('ai-input');
      input.value = `/${name} `;
      input.focus();
    }

    // --- Slash Command Autocomplete ---
    document.getElementById('ai-input').addEventListener('input', function(e) {
      const text = this.value;
      const menu = document.getElementById('ai-slash-menu');

      if (text.startsWith('/') && !text.includes('\n')) {
        const query = text.slice(1).toLowerCase();
        const matches = allSkills.filter(s => s.user_invocable !== false && s.name.toLowerCase().startsWith(query));

        if (matches.length > 0 && query.length > 0) {
          menu.innerHTML = '';
          matches.forEach(s => {
            const item = document.createElement('div');
            item.className = 'slash-item';
            item.addEventListener('click', () => selectSlashCommand(s.name));
            const nameSpan = document.createElement('span');
            nameSpan.className = 'slash-name';
            nameSpan.textContent = '/' + s.name;
            const descSpan = document.createElement('span');
            descSpan.className = 'slash-desc';
            descSpan.textContent = s.description || '';
            item.appendChild(nameSpan);
            item.appendChild(descSpan);
            menu.appendChild(item);
          });
          menu.style.display = 'block';
        } else {
          menu.style.display = 'none';
        }
      } else {
        menu.style.display = 'none';
      }
    });

    function selectSlashCommand(name) {
      document.getElementById('ai-input').value = `/${name} `;
      document.getElementById('ai-slash-menu').style.display = 'none';
      document.getElementById('ai-input').focus();
    }

    // --- AI Input Keyboard Shortcut ---
    document.getElementById('ai-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendAiMessage();
      }
    });
  </script>
</body>
</html>

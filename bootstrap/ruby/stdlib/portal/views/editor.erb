<!DOCTYPE html>
<html>
<head>
  <title>Editor - <%= server_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { margin: 0; background: #1e1e1e; color: #d4d4d4; overflow: hidden; }
    #editor-layout { display: grid; grid-template-columns: 250px 1fr 300px 320px; grid-template-rows: auto 1fr auto; height: 100vh; }
    #editor-layout.panel-hidden { grid-template-columns: 250px 1fr 320px; }
    #editor-layout.panel-left { grid-template-columns: 250px 1fr 320px; }
    #editor-layout.ai-hidden { grid-template-columns: 250px 1fr 300px; }
    #editor-layout.panel-hidden.ai-hidden { grid-template-columns: 250px 1fr; }
    #editor-layout.panel-left.ai-hidden { grid-template-columns: 250px 1fr; }
    #nav { grid-column: 1 / -1; background: #333; padding: 8px 16px; display: flex; align-items: center; gap: 12px; }
    #left-sidebar { display: flex; flex-direction: column; overflow: hidden; background: #252526; border-right: 1px solid #444; }
    #file-tree { overflow-y: auto; padding: 8px; flex: 1 1 auto; min-height: 0; }
    #monaco-container { min-height: 0; min-width: 0; overflow: hidden; }
    #status-bar { grid-column: 1 / -1; background: #007acc; color: white; padding: 4px 16px; font-size: 12px; }
    .file-item { cursor: pointer; padding: 2px 4px; font-size: 13px; font-family: monospace; white-space: nowrap; }
    .file-item:hover { background: #37373d; }
    .dir-item { cursor: pointer; padding: 2px 4px; font-size: 13px; font-family: monospace; color: #c8c8c8; white-space: nowrap; user-select: none; }
    .dir-item:hover { background: #37373d; }
    .dir-item .arrow { display: inline-block; width: 12px; transition: transform 0.1s; }
    .dir-item.collapsed .arrow { transform: rotate(-90deg); }
    .dir-children { overflow: hidden; }
    .dir-children.hidden { display: none; }
    #git-panel { overflow-y: auto; background: #252526; padding: 12px; border-left: 1px solid #444; font-size: 13px; }
    #git-panel.hidden { display: none; }
    #git-panel.docked-left { border-left: none; border-top: 1px solid #444; flex: 0 0 auto; max-height: 50%; }
    .dock-btn { background: none; border: none; color: #808080; cursor: pointer; font-size: 14px; padding: 0 4px; }
    .dock-btn:hover { color: #d4d4d4; }
    #git-panel h6 { color: #ccc; margin-top: 12px; margin-bottom: 6px; }
    .change-item { padding: 2px 4px; cursor: pointer; font-family: monospace; white-space: nowrap; }
    .change-item:hover { background: #37373d; }
    .change-new { color: #4ec9b0; }
    .change-modified { color: #e2c08d; }
    .change-deleted { color: #f48771; text-decoration: line-through; }
    .commit-entry { font-size: 12px; border-bottom: 1px solid #333; padding: 4px 0; }
    .commit-sha { color: #569cd6; font-family: monospace; }
    .commit-msg { color: #d4d4d4; }
    .commit-meta { color: #808080; font-size: 11px; }
    .file-modified-dot { color: #e2c08d; margin-left: 4px; }
    #ai-panel { background: #252526; border-left: 1px solid #444; font-size: 13px; display: flex; flex-direction: column; overflow: hidden; }
    #ai-panel.hidden { display: none; }
    #ai-panel.docked-left { border-left: none; border-top: 1px solid #444; flex: 0 0 auto; max-height: 50%; }
    #ai-panel-header { padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #444; }
    #editor-layout.ai-visible { grid-template-columns: 250px 1fr 350px; }
    #editor-layout.ai-visible.panel-hidden { grid-template-columns: 250px 1fr 350px; }
    #editor-layout.ai-visible.panel-left { grid-template-columns: 250px 1fr 350px; }
    #ai-messages { flex: 1; overflow-y: auto; padding: 8px; font-family: -apple-system, sans-serif; font-size: 13px; }
    .ai-msg { margin-bottom: 12px; line-height: 1.4; }
    .ai-msg.user { color: #569cd6; }
    .ai-msg.user::before { content: 'You: '; font-weight: bold; }
    .ai-msg.assistant { color: #d4d4d4; }
    .ai-msg.assistant pre { background: #1e1e1e; padding: 8px; border-radius: 4px; overflow-x: auto; margin: 4px 0; }
    .ai-msg.assistant code { font-family: 'Cascadia Code', monospace; font-size: 12px; }
    .ai-tool-call { padding: 4px 8px; margin: 2px 8px; background: #2d2d30; border-left: 2px solid #007acc; font-size: 12px; color: #808080; }
    .ai-tool-call.running::after { content: ' ⏳'; }
    .ai-tool-call.done::after { content: ' ✓'; color: #4ec9b0; }
    .ai-tool-call.error::after { content: ' ✗'; color: #f48771; }
    .ai-input-row { padding: 8px; border-top: 1px solid #444; display: flex; gap: 4px; align-items: flex-end; }
    .ai-input-row textarea { flex: 1; background: #3c3c3c; color: #d4d4d4; border: 1px solid #555; border-radius: 4px; padding: 6px 8px; font-size: 13px; resize: none; font-family: -apple-system, sans-serif; }
    .ai-input-row button { background: #007acc; color: white; border: none; border-radius: 4px; padding: 6px 12px; cursor: pointer; font-size: 12px; white-space: nowrap; }
    .ai-input-row button:hover { background: #005999; }
    .ai-input-row button.stop { background: #c53d3d; }
    #ai-setup { padding: 16px; text-align: center; }
    #ai-setup.hidden { display: none; }
    #logs-panel.hidden { display: none !important; }
    #ai-setup input { width: 100%; background: #3c3c3c; color: #d4d4d4; border: 1px solid #555; border-radius: 4px; padding: 6px 8px; margin: 8px 0; font-size: 13px; }
    #ai-setup button { background: #007acc; color: white; border: none; border-radius: 4px; padding: 8px 16px; cursor: pointer; }
    #ai-skills-bar { padding: 4px 8px; border-top: 1px solid #444; display: flex; flex-wrap: wrap; gap: 4px; }
    .skill-chip { background: #2d2d30; color: #808080; border: 1px solid #555; border-radius: 12px; padding: 2px 8px; font-size: 11px; cursor: pointer; }
    .skill-chip:hover { background: #3c3c3c; color: #d4d4d4; }
    .skill-chip.active { background: #007acc; color: white; border-color: #007acc; }
    #ai-slash-menu { position: absolute; bottom: 100%; left: 8px; right: 8px; background: #252526; border: 1px solid #444; border-radius: 4px; max-height: 200px; overflow-y: auto; display: none; z-index: 100; }
    #ai-slash-menu .slash-item { padding: 6px 10px; cursor: pointer; font-size: 12px; }
    #ai-slash-menu .slash-item:hover, #ai-slash-menu .slash-item.selected { background: #094771; }
    #ai-slash-menu .slash-item .slash-name { color: #569cd6; }
    #ai-slash-menu .slash-item .slash-desc { color: #808080; margin-left: 8px; }
    .provider-tab { background: #333; color: #888; border: 1px solid #555; padding: 2px 8px; font-size: 11px; cursor: pointer; border-radius: 3px; }
    .provider-tab.active { background: #555; color: #fff; }
    .provider-tab.configured::after { content: " \2713"; color: #5a5; }
    .toggle-switch { position: relative; display: inline-block; width: 28px; height: 16px; flex-shrink: 0; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-switch .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #555; border-radius: 8px; transition: 0.2s; }
    .toggle-switch .slider::before { content: ""; position: absolute; height: 12px; width: 12px; left: 2px; bottom: 2px; background: #aaa; border-radius: 50%; transition: 0.2s; }
    .toggle-switch input:checked + .slider { background: #2a6; }
    .toggle-switch input:checked + .slider::before { transform: translateX(12px); background: #fff; }
    .toggle-switch input:disabled + .slider { opacity: 0.4; cursor: not-allowed; }
    .provider-row { display: flex; align-items: center; gap: 8px; padding: 3px 0; font-size: 11px; }
    .provider-row .provider-name { flex: 1; cursor: pointer; }
    .provider-row .provider-name.active { color: #fff; font-weight: bold; }
    .custom-provider-item { display: flex; align-items: center; gap: 6px; padding: 3px 0; font-size: 11px; color: #aaa; }
    .custom-provider-item .cp-name { flex: 1; }
    .custom-provider-item .cp-mode { color: #666; font-size: 10px; }
    .cp-btn { background: none; border: 1px solid #555; color: #888; font-size: 10px; padding: 1px 5px; cursor: pointer; border-radius: 2px; }
    .cp-btn:hover { color: #fff; border-color: #888; }
  </style>
</head>
<body>
  <div id="editor-layout" class="panel-left ai-visible">
    <div id="nav">
      <select id="repo-select" class="form-select form-select-sm bg-dark text-light" style="width: 200px;">
        <% repos.each do |repo| %>
          <option value="<%= repo %>"><%= repo %></option>
        <% end %>
      </select>
      <button id="save-btn" class="btn btn-sm btn-success" onclick="saveFile()">Save</button>
      <button id="new-file-btn" class="btn btn-sm btn-outline-info" onclick="newFile()">New File</button>
      <button id="delete-file-btn" class="btn btn-sm btn-outline-danger" onclick="deleteFile()">Delete File</button>
      <button id="git-toggle" class="btn btn-sm btn-info ms-auto" onclick="toggleGitPanel()">Source Control</button>
      <button class="btn btn-sm btn-outline-secondary ms-2" onclick="toggleLogsPanel()" title="Build Logs">Logs</button>
      <button class="btn btn-sm btn-outline-secondary ms-2" onclick="toggleAiPanel()" title="AI Assistant">AI</button>
      <a href="/git" class="btn btn-sm btn-outline-info">Git Dashboard</a>
      <a href="/git" class="btn btn-sm btn-outline-light">Back</a>
    </div>
    <div id="left-sidebar">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 8px;border-bottom:1px solid #333;">
        <span style="font-size:11px;color:#808080;text-transform:uppercase;font-weight:600;">Files</span>
        <button onclick="loadFileTree()" title="Refresh file list" style="background:none;border:none;color:#808080;cursor:pointer;font-size:14px;padding:0 2px;line-height:1;" onmouseover="this.style.color='#ccc'" onmouseout="this.style.color='#808080'">&#x21bb;</button>
      </div>
      <div id="file-tree"></div>
      <div id="git-panel" class="docked-left">
        <div class="d-flex justify-content-between align-items-center">
          <strong>Source Control</strong>
          <div>
            <button class="dock-btn" id="dock-toggle" onclick="toggleDockSide()" title="Move panel">&#8644;</button>
            <span id="branch-badge" class="badge bg-info">...</span>
          </div>
        </div>

        <h6>Changed Files</h6>
        <div id="changes-list"><span class="text-muted">Loading...</span></div>

        <h6>Commit</h6>
        <input id="commit-msg" class="form-control form-control-sm bg-dark text-light mb-2" placeholder="Commit message...">
        <button class="btn btn-sm btn-success w-100" onclick="commitAndPush()">Commit &amp; Push</button>
        <div id="commit-status" class="mt-2" style="font-size: 12px;"></div>

        <h6>Recent Commits</h6>
        <div id="recent-commits"><span class="text-muted">Loading...</span></div>
      </div>
    </div>
    <div id="monaco-container"></div>
    <div id="ai-panel">
      <div id="ai-panel-header">
        <span style="font-weight: bold; font-size: 12px; text-transform: uppercase; color: #808080;">AI Assistant</span>
        <span style="display: flex; align-items: center; gap: 6px;">
          <select id="ai-model-select" onchange="updateSelectedModel()" style="background: #2d2d2d; color: #ccc; border: 1px solid #555; font-size: 11px; padding: 2px 4px; max-width: 160px;">
          </select>
          <button class="dock-btn" onclick="toggleAiSetup()" title="API key settings" style="font-size: 14px;">&#9881;</button>
          <button class="dock-btn" onclick="toggleAiDock()" title="Toggle dock side">&#8862;</button>
        </span>
      </div>
      <div id="ai-setup" class="hidden">
        <p style="color: #808080; font-size: 12px;">AI Providers:</p>
        <div id="ai-provider-list" style="margin-bottom: 8px;"></div>
        <div id="ai-key-form" style="margin-bottom: 8px;">
          <input type="password" id="ai-key-input" placeholder="sk-ant-..." style="width: 70%;">
          <button onclick="saveApiKey()">Save Key</button>
        </div>
        <div id="ai-provider-status" style="margin-top: 6px; font-size: 11px; color: #808080;"></div>
        <p id="ai-key-status" style="color: #808080; font-size: 11px; margin-top: 4px;"></p>
        <div style="border-top: 1px solid #333; margin-top: 8px; padding-top: 8px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
            <span style="color: #808080; font-size: 11px; font-weight: bold;">Custom LLMs</span>
            <button class="cp-btn" id="add-custom-btn" onclick="showAddCustomForm()">+ Add</button>
          </div>
          <div id="custom-provider-list"></div>
          <div id="custom-provider-form" class="hidden" style="border: 1px solid #444; padding: 6px; border-radius: 3px; margin-top: 4px;">
            <input type="text" id="cp-name" placeholder="Name (e.g. Local Llama)" style="width: 100%; margin-bottom: 4px; font-size: 11px;">
            <input type="text" id="cp-url" placeholder="http://localhost:11434" style="width: 100%; margin-bottom: 4px; font-size: 11px;">
            <div style="display: flex; gap: 4px; margin-bottom: 4px;">
              <select id="cp-mode" style="flex: 1; font-size: 11px;">
                <option value="ollama">Ollama</option>
                <option value="openai">OpenAI-compatible</option>
                <option value="anthropic">Anthropic-compatible</option>
              </select>
              <input type="password" id="cp-key" placeholder="API key (optional)" style="flex: 1; font-size: 11px;">
            </div>
            <div style="display: flex; gap: 4px;">
              <button class="cp-btn" onclick="saveCustomProvider()">Save</button>
              <button class="cp-btn" onclick="hideAddCustomForm()">Cancel</button>
            </div>
            <p id="cp-status" style="color: #808080; font-size: 10px; margin: 4px 0 0;"></p>
          </div>
        </div>
      </div>
      <div id="ai-chat-area" class="hidden" style="display: flex; flex-direction: column; flex: 1; min-height: 0;">
        <div id="ai-messages"></div>
        <div id="ai-skills-bar"></div>
        <div class="ai-input-row" style="position: relative;">
          <div id="ai-slash-menu"></div>
          <textarea id="ai-input" placeholder="Ask Claude... (/ for skills)" rows="2"></textarea>
          <button onclick="sendAiMessage()" id="ai-send-btn">Send</button>
          <button onclick="stopAi()" id="ai-stop-btn" class="stop" style="display:none;">Stop</button>
        </div>
      </div>
    </div>
    <div id="logs-panel" class="hidden" style="position:fixed;right:340px;top:40px;bottom:24px;width:400px;background:#1e1e1e;border-left:1px solid #333;display:flex;flex-direction:column;z-index:10;">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;border-bottom:1px solid #333;">
        <span style="font-weight:600;color:#ccc;">Build Logs</span>
        <div style="display:flex;gap:4px;">
          <button onclick="filterLogs('all')" id="logs-filter-all" style="padding:2px 8px;background:#555;color:#ccc;border:1px solid #555;border-radius:3px;cursor:pointer;font-size:11px;">All</button>
          <button onclick="filterLogs('error')" id="logs-filter-error" style="padding:2px 8px;background:#333;color:#ccc;border:1px solid #555;border-radius:3px;cursor:pointer;font-size:11px;">Errors</button>
          <button onclick="refreshLogs()" style="padding:2px 8px;background:#333;color:#ccc;border:1px solid #555;border-radius:3px;cursor:pointer;font-size:11px;">&#x21bb;</button>
          <button onclick="toggleLogsPanel()" style="padding:2px 8px;background:#333;color:#ccc;border:1px solid #555;border-radius:3px;cursor:pointer;font-size:11px;">&#x2715;</button>
        </div>
      </div>
      <div id="logs-entries" style="overflow-y:auto;flex:1;padding:8px;font-family:monospace;font-size:12px;color:#ccc;"></div>
    </div>
    <div id="status-bar">Ready</div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>
  <script>
    let editor;
    let currentFile = null;
    let gitPanelVisible = true;
    let gitPanelDock = 'left';
    let changedFiles = new Set();
    let aiPanelVisible = true;
    let aiPanelDock = 'right';
    let aiConversation = [];
    let aiAbortController = null;
    let aiRunning = false;
    let allSkills = [];
    let selectedProvider = 'anthropic';
    let selectedModel = null;
    const AI_BASE_URL = '';
    const repoSelect = document.getElementById('repo-select');

    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' } });
    require(['vs/editor/editor.main'], function () {
      editor = monaco.editor.create(document.getElementById('monaco-container'), {
        value: '// Select a file to edit',
        language: 'ruby',
        theme: 'vs-dark',
        automaticLayout: true
      });
      loadFileTree();
      checkApiKeyAndShow();
      loadSkills();
    });

    repoSelect.addEventListener('change', loadFileTree);

    function toggleGitPanel() {
      gitPanelVisible = !gitPanelVisible;
      const panel = document.getElementById('git-panel');
      panel.classList.toggle('hidden', !gitPanelVisible);
      applyLayoutClasses();
      if (editor) editor.layout();
    }

    function toggleDockSide() {
      const panel = document.getElementById('git-panel');
      const sidebar = document.getElementById('left-sidebar');

      if (gitPanelDock === 'right') {
        gitPanelDock = 'left';
        sidebar.appendChild(panel);
        panel.classList.add('docked-left');
        panel.classList.remove('hidden');
        gitPanelVisible = true;
      } else {
        gitPanelDock = 'right';
        // Insert after monaco-container to restore as 3rd grid column
        document.getElementById('monaco-container').after(panel);
        panel.classList.remove('docked-left');
      }
      applyLayoutClasses();
      if (editor) editor.layout();
    }

    function applyLayoutClasses() {
      const layout = document.getElementById('editor-layout');
      layout.classList.remove('panel-hidden', 'panel-left', 'ai-visible', 'ai-hidden');

      if (!gitPanelVisible || gitPanelDock === 'left') {
        if (!gitPanelVisible) layout.classList.add('panel-hidden');
        if (gitPanelDock === 'left' && gitPanelVisible) layout.classList.add('panel-left');
      }

      if (aiPanelVisible && aiPanelDock === 'right') {
        layout.classList.add('ai-visible');
      }
      if (typeof aiPanelVisible !== 'undefined' && !aiPanelVisible) {
        layout.classList.add('ai-hidden');
      }
    }

    function getRepoParts() {
      const repo = repoSelect.value;
      const parts = repo.split('/');
      return { ns: parts[0], name: parts[1], repo: repo };
    }

    function loadFileTree() {
      pullAndRefresh().then(() => loadRecentCommits());
    }

    function pullAndRefresh() {
      const { repo } = getRepoParts();
      return fetch('/editor/api/pull?repo=' + encodeURIComponent(repo), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: '{}'
      })
      .then(r => r.json())
      .then(data => {
        document.getElementById('branch-badge').textContent = data.branch;
        renderFileTree(data.files);
        return loadGitStatus();
      })
      .catch(() => {
        // Fallback to regular file listing if pull fails
        const { repo } = getRepoParts();
        return fetch('/api/editor/files?repo=' + encodeURIComponent(repo))
          .then(r => r.json())
          .then(data => renderFileTree(data.files));
      });
    }

    function loadGitStatus() {
      const { ns, name } = getRepoParts();
      return fetch('/git/api/repos/' + ns + '/' + name + '/status')
        .then(r => r.json())
        .then(data => {
          changedFiles = new Set(data.changes.map(c => c.path));
          renderChanges(data.changes);
          updateFileTreeIndicators();
        });
    }

    function renderChanges(changes) {
      const el = document.getElementById('changes-list');
      if (changes.length === 0) {
        el.innerHTML = '<span class="text-muted">No changes</span>';
        return;
      }
      el.innerHTML = changes.map(c => {
        const status = Array.isArray(c.status) ? c.status[0] : c.status;
        const cls = status === 'new' ? 'change-new' : status === 'deleted' ? 'change-deleted' : 'change-modified';
        const escaped = c.path.replace(/'/g, "\\'");
        return '<div class="change-item ' + cls + '" onclick="openFile(\'' + escaped + '\')">' + c.path + '</div>';
      }).join('');
    }

    function updateFileTreeIndicators() {
      document.querySelectorAll('.file-item').forEach(el => {
        const dot = el.querySelector('.file-modified-dot');
        if (dot) dot.remove();
        const fullPath = el.dataset.path;
        if (fullPath && changedFiles.has(fullPath)) {
          const span = document.createElement('span');
          span.className = 'file-modified-dot';
          span.textContent = ' \u25cf';
          el.appendChild(span);
        }
      });
    }

    function loadRecentCommits() {
      const { ns, name } = getRepoParts();
      fetch('/git/api/repos/' + ns + '/' + name + '/log?limit=5')
        .then(r => r.json())
        .then(data => {
          const el = document.getElementById('recent-commits');
          if (!data.commits || data.commits.length === 0) {
            el.innerHTML = '<span class="text-muted">No commits</span>';
            return;
          }
          el.innerHTML = data.commits.map(c =>
            '<div class="commit-entry">' +
              '<span class="commit-sha">' + c.oid + '</span> ' +
              '<span class="commit-msg">' + c.message + '</span>' +
              '<div class="commit-meta">' + c.author + '</div>' +
            '</div>'
          ).join('');
        });
    }

    function commitAndPush() {
      const msg = document.getElementById('commit-msg').value;
      if (!msg) { alert('Enter a commit message'); return; }
      const { ns, name } = getRepoParts();
      const statusEl = document.getElementById('commit-status');
      statusEl.innerHTML = '<span class="text-warning">Committing...</span>';

      fetch('/git/api/repos/' + ns + '/' + name + '/commit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg })
      })
      .then(r => r.json())
      .then(data => {
        if (data.status === 'committed') {
          statusEl.innerHTML = '<span class="text-success">Committed \u2014 reloading area...</span>';
          document.getElementById('commit-msg').value = '';
          pullAndRefresh();
          loadRecentCommits();
          setTimeout(loadBuildLogs, 2000);
        } else {
          statusEl.innerHTML = '<span class="text-danger">Error: ' + (data.message || 'Unknown') + '</span>';
        }
      })
      .catch(err => {
        statusEl.innerHTML = '<span class="text-danger">Failed: ' + err.message + '</span>';
      });
    }

    function renderFileTree(files) {
      const tree = document.getElementById('file-tree');
      tree.innerHTML = '';
      const root = {};
      files.forEach(f => {
        const parts = f.path.split('/');
        let node = root;
        parts.forEach((p, i) => {
          if (i === parts.length - 1) {
            if (!node._files) node._files = [];
            node._files.push({ name: p, path: f.path });
          } else {
            if (!node[p]) node[p] = {};
            node = node[p];
          }
        });
      });
      renderNode(root, tree, 0);
    }

    function renderNode(node, parent, depth) {
      const dirs = Object.keys(node).filter(k => k !== '_files').sort();
      dirs.forEach(name => {
        const dir = document.createElement('div');
        dir.className = 'dir-item';
        dir.style.paddingLeft = (depth * 16 + 4) + 'px';
        dir.innerHTML = '<span class="arrow">&#9660;</span> ' + name;
        const children = document.createElement('div');
        children.className = 'dir-children';
        dir.onclick = () => {
          dir.classList.toggle('collapsed');
          children.classList.toggle('hidden');
        };
        parent.appendChild(dir);
        parent.appendChild(children);
        renderNode(node[name], children, depth + 1);
      });
      if (node._files) {
        node._files.sort((a, b) => a.name.localeCompare(b.name)).forEach(f => {
          const el = document.createElement('div');
          el.className = 'file-item';
          el.style.paddingLeft = (depth * 16 + 4) + 'px';
          el.textContent = f.name;
          el.dataset.path = f.path;
          el.onclick = () => openFile(f.path);
          parent.appendChild(el);
        });
      }
    }

    function openFile(path) {
      const repo = repoSelect.value;
      fetch('/api/editor/files/' + encodeURIComponent(path) + '?repo=' + encodeURIComponent(repo))
        .then(r => r.json())
        .then(data => {
          currentFile = path;
          const ext = path.split('.').pop().toLowerCase();
          const langMap = {
            rb: 'ruby', erb: 'html', yml: 'yaml', yaml: 'yaml',
            js: 'javascript', jsx: 'javascript', ts: 'typescript', tsx: 'typescript',
            svelte: 'html', vue: 'html', html: 'html', htm: 'html',
            css: 'css', scss: 'scss', less: 'less',
            json: 'json', md: 'markdown', sql: 'sql', sh: 'shell',
            xml: 'xml', svg: 'xml'
          };
          const lang = langMap[ext] || 'plaintext';
          monaco.editor.setModelLanguage(editor.getModel(), lang);
          editor.setValue(data.content);
          document.getElementById('status-bar').textContent = path;
        });
    }

    function saveFile() {
      if (!currentFile) return;
      const repo = repoSelect.value;
      fetch('/api/editor/files/' + encodeURIComponent(currentFile) + '?repo=' + encodeURIComponent(repo), {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: editor.getValue() })
      }).then(r => {
        document.getElementById('status-bar').textContent = r.ok ? currentFile + ' (saved)' : 'Save failed';
        if (r.ok) loadGitStatus();
      });
    }

    function newFile() {
      const name = prompt('File name (e.g. rooms/new_room.rb):');
      if (!name) return;
      const repo = repoSelect.value;
      fetch('/api/editor/files/' + encodeURIComponent(name) + '?repo=' + encodeURIComponent(repo), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: '' })
      }).then(r => {
        if (r.ok) { loadFileTree(); openFile(name); }
      });
    }

    function deleteFile() {
      if (!currentFile) return;
      if (!confirm('Delete ' + currentFile + '?')) return;
      const repo = repoSelect.value;
      fetch('/api/editor/files/' + encodeURIComponent(currentFile) + '?repo=' + encodeURIComponent(repo), {
        method: 'DELETE'
      }).then(r => {
        if (r.ok) {
          currentFile = null;
          editor.setValue('');
          document.getElementById('status-bar').textContent = 'No file selected';
          loadFileTree();
        }
      });
    }

    document.addEventListener('keydown', e => {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        saveFile();
      }
    });

    // -----------------------------------------------------------------------
    // Build Logs
    // -----------------------------------------------------------------------

    let currentLogFilter = 'all';

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    async function loadBuildLogs() {
      const { ns, name: repoName } = getRepoParts();
      try {
        // Fetch logs from both main and @dev area keys
        const allLogs = [];
        for (const key of [repoName, `${repoName}@dev`]) {
          const r = await fetch(`/api/builder/${ns}/${key}/logs?limit=100&level=${currentLogFilter}`);
          if (r.ok) {
            const logs = await r.json();
            allLogs.push(...logs);
          }
        }
        // Sort by timestamp and deduplicate
        allLogs.sort((a, b) => a.timestamp.localeCompare(b.timestamp));
        renderLogs(allLogs);
      } catch (e) {
        console.error('Failed to load build logs:', e);
      }
    }

    function renderLogs(logs) {
      const el = document.getElementById('logs-entries');
      if (!logs || !logs.length) {
        el.innerHTML = '<div style="color:#666;padding:12px;">No logs yet. Logs appear after area load/reload.</div>';
        return;
      }
      el.innerHTML = logs.slice().reverse().map(e => {
        const color = e.level === 'error' ? '#f44' : e.level === 'warn' ? '#fa0' : '#666';
        const bt = e.backtrace ? `<pre style="color:#999;margin:4px 0 0 16px;white-space:pre-wrap;font-size:11px;">${escapeHtml(e.backtrace)}</pre>` : '';
        return `<div style="margin-bottom:6px;border-left:3px solid ${color};padding:4px 8px;">
          <span style="color:#555;font-size:11px;">${escapeHtml(e.ts || '')}</span>
          <span style="color:${color};font-weight:600;margin:0 6px;">[${escapeHtml(e.event || '')}]</span>
          <span style="color:#ccc;">${escapeHtml(e.message || '')}</span>${bt}
        </div>`;
      }).join('');
    }

    function filterLogs(level) {
      currentLogFilter = level;
      document.getElementById('logs-filter-all').style.background = level === 'all' ? '#555' : '#333';
      document.getElementById('logs-filter-error').style.background = level === 'error' ? '#555' : '#333';
      loadBuildLogs();
    }

    function refreshLogs() { loadBuildLogs(); }

    function toggleLogsPanel() {
      const panel = document.getElementById('logs-panel');
      panel.classList.toggle('hidden');
      if (!panel.classList.contains('hidden')) loadBuildLogs();
    }


    // --- Tool Execution ---
    async function executeTool(name, input) {
      const { ns, name: repoName, repo } = getRepoParts();
      const baseUrl = '';

      switch (name) {
        case 'list_files': {
          const r = await fetch(`${baseUrl}/api/editor/files?repo=${repo}`);
          return await r.json();
        }
        case 'read_file': {
          const r = await fetch(`${baseUrl}/api/editor/files/${encodeURIComponent(input.path)}?repo=${repo}`);
          if (!r.ok) return { error: `File not found: ${input.path}` };
          const data = await r.json();
          return { content: data.content };
        }
        case 'write_file': {
          const r = await fetch(`${baseUrl}/api/editor/files/${encodeURIComponent(input.path)}?repo=${repo}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: input.content })
          });
          if (!r.ok) return { error: `Failed to write: ${input.path}` };
          if (input.path === currentFile) {
            editor.setValue(input.content);
          }
          loadGitStatus();
          return { status: 'ok' };
        }
        case 'create_file': {
          const r = await fetch(`${baseUrl}/api/editor/files/${encodeURIComponent(input.path)}?repo=${repo}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: input.content })
          });
          if (!r.ok) {
            const err = await r.json().catch(() => ({}));
            return { error: err.error || `Failed to create: ${input.path}` };
          }
          loadFileTree();
          loadGitStatus();
          return { status: 'created' };
        }
        case 'delete_file': {
          const r = await fetch(`${baseUrl}/api/editor/files/${encodeURIComponent(input.path)}?repo=${repo}`, {
            method: 'DELETE'
          });
          if (!r.ok) return { error: `Failed to delete: ${input.path}` };
          loadFileTree();
          loadGitStatus();
          return { status: 'deleted' };
        }
        case 'git_status': {
          const r = await fetch(`${baseUrl}/git/api/repos/${ns}/${repoName}/status`);
          return await r.json();
        }
        case 'git_log': {
          const limit = input.limit || 10;
          const r = await fetch(`${baseUrl}/git/api/repos/${ns}/${repoName}/log?limit=${limit}`);
          return await r.json();
        }
        case 'git_commit': {
          const r = await fetch(`${baseUrl}/git/api/repos/${ns}/${repoName}/commit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: input.message })
          });
          if (!r.ok) return { error: 'Commit failed' };
          const commitResult = await r.json();
          pullAndRefresh();
          loadRecentCommits();
          // Wait for async build/reload, then collect all logs since the commit
          const commitTime = new Date().toISOString();
          await new Promise(resolve => setTimeout(resolve, 3000));
          loadBuildLogs();
          try {
            const allLogs = [];
            for (const key of [repoName, `${repoName}@dev`]) {
              const logsResp = await fetch(`/api/builder/${ns}/${key}/logs?limit=20`);
              if (logsResp.ok) {
                const logs = await logsResp.json();
                const recent = logs.filter(e => e.timestamp >= commitTime);
                allLogs.push(...recent.map(e => `[${e.level}] [${e.event}] ${e.message}`));
              }
            }
            if (allLogs.length > 0) {
              commitResult.build_logs = allLogs;
            }
          } catch (e) {}
          return commitResult;
        }
        case 'play_command': {
          const r = await fetch(`${baseUrl}/play/command`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input: input.command })
          });
          if (!r.ok) return { error: 'Play session not active. Start a play session first.' };
          return await r.json();
        }
        case 'view_build_logs': {
          const params = new URLSearchParams();
          if (input.limit) params.set('limit', input.limit);
          if (input.level) params.set('level', input.level);
          const allLogs = [];
          for (const key of [repoName, `${repoName}@dev`]) {
            const r = await fetch(`/api/builder/${ns}/${key}/logs?${params}`);
            if (r.ok) allLogs.push(...(await r.json()));
          }
          allLogs.sort((a, b) => a.timestamp.localeCompare(b.timestamp));
          return allLogs;
        }
        default:
          return { error: `Unknown tool: ${name}` };
      }
    }

    // --- SSE Stream Parser ---
    async function parseSSEStream(response, signal) {
      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let currentMessage = { content: [], stop_reason: null };
      let currentBlock = null;
      let currentBlockIndex = -1;
      let textEl = null;
      let toolJsonStr = '';

      try {
        while (true) {
          if (signal && signal.aborted) return null;
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop();

          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const data = line.slice(6);
              if (data === '[DONE]') return currentMessage;

              try {
                const event = JSON.parse(data);

                switch (event.type) {
                  case 'message_start':
                    currentMessage = { content: [], stop_reason: null };
                    break;

                  case 'content_block_start':
                    currentBlockIndex = event.index;
                    if (event.content_block.type === 'text') {
                      currentBlock = { type: 'text', text: '' };
                      textEl = appendAiMessage('assistant', '');
                    } else if (event.content_block.type === 'tool_use') {
                      currentBlock = { type: 'tool_use', id: event.content_block.id, name: event.content_block.name, input: {} };
                      toolJsonStr = '';
                    }
                    break;

                  case 'content_block_delta':
                    if (event.delta.type === 'text_delta' && currentBlock && currentBlock.type === 'text') {
                      currentBlock.text += event.delta.text;
                      if (textEl) textEl.innerHTML = renderMarkdown(currentBlock.text);
                    } else if (event.delta.type === 'input_json_delta' && currentBlock && currentBlock.type === 'tool_use') {
                      toolJsonStr += event.delta.partial_json;
                    }
                    break;

                  case 'content_block_stop':
                    if (currentBlock) {
                      if (currentBlock.type === 'tool_use' && toolJsonStr) {
                        try { currentBlock.input = JSON.parse(toolJsonStr); } catch (e) {}
                      }
                      currentMessage.content.push(currentBlock);
                      currentBlock = null;
                      textEl = null;
                      toolJsonStr = '';
                    }
                    break;

                  case 'message_delta':
                    if (event.delta && event.delta.stop_reason) {
                      currentMessage.stop_reason = event.delta.stop_reason;
                    }
                    break;

                  case 'message_stop':
                    return currentMessage;
                }
              } catch (e) {
                // Skip malformed JSON lines
              }
            }
          }
        }
      } catch (e) {
        if (e.name !== 'AbortError') throw e;
      }

      return currentMessage;
    }

    // --- Agent Loop ---
    async function runAgentLoop() {
      aiRunning = true;
      document.getElementById('ai-send-btn').style.display = 'none';
      document.getElementById('ai-stop-btn').style.display = '';

      const systemPrompt = await buildSystemPrompt();

      while (aiRunning) {
        aiAbortController = new AbortController();

        let response;
        try {
          response = await fetch(`${AI_BASE_URL}/api/ai/stream`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            signal: aiAbortController.signal,
            body: JSON.stringify({
              messages: aiConversation,
              tools: AI_TOOLS,
              system: systemPrompt,
              provider: selectedProvider,
              model: selectedModel,
            })
          });
        } catch (e) {
          if (e.name === 'AbortError') break;
          appendAiMessage('assistant', `Error: ${e.message}`);
          break;
        }

        if (!response.ok) {
          const err = await response.text();
          appendAiMessage('assistant', `Error: ${err}`);
          break;
        }

        const result = await parseSSEStream(response, aiAbortController.signal);

        if (!result || !aiRunning) break;

        aiConversation.push({ role: 'assistant', content: result.content });

        if (result.stop_reason === 'end_turn') {
          break;
        }

        if (result.stop_reason === 'tool_use') {
          const toolResults = [];
          for (const block of result.content) {
            if (block.type === 'tool_use') {
              const toolEl = showToolCall(block.name, block.input);
              try {
                const toolResult = await executeTool(block.name, block.input);
                markToolDone(toolEl);
                toolResults.push({
                  type: 'tool_result',
                  tool_use_id: block.id,
                  content: JSON.stringify(toolResult)
                });
              } catch (e) {
                markToolError(toolEl, e.message);
                toolResults.push({
                  type: 'tool_result',
                  tool_use_id: block.id,
                  content: JSON.stringify({ error: e.message }),
                  is_error: true
                });
              }
            }
          }
          aiConversation.push({ role: 'user', content: toolResults });
          continue;
        }

        break;
      }

      aiRunning = false;
      document.getElementById('ai-send-btn').style.display = '';
      document.getElementById('ai-stop-btn').style.display = 'none';
    }

    // --- AI UI Helpers ---
    function appendAiMessage(role, text) {
      const el = document.createElement('div');
      el.className = `ai-msg ${role}`;
      el.innerHTML = renderMarkdown(text);
      document.getElementById('ai-messages').appendChild(el);
      el.scrollIntoView({ behavior: 'smooth', block: 'end' });
      return el;
    }

    function showToolCall(name, input) {
      const el = document.createElement('div');
      el.className = 'ai-tool-call running';
      const desc = name === 'read_file' ? `Reading ${input.path}` :
                   name === 'write_file' ? `Writing ${input.path}` :
                   name === 'create_file' ? `Creating ${input.path}` :
                   name === 'delete_file' ? `Deleting ${input.path}` :
                   name === 'git_commit' ? `Committing: ${input.message}` :
                   name === 'play_command' ? `> ${input.command}` :
                   name;
      el.textContent = desc;
      document.getElementById('ai-messages').appendChild(el);
      el.scrollIntoView({ behavior: 'smooth', block: 'end' });
      return el;
    }

    function markToolDone(el) { el.classList.remove('running'); el.classList.add('done'); }
    function markToolError(el, msg) { el.classList.remove('running'); el.classList.add('error'); el.title = msg; }

    function renderMarkdown(text) {
      if (!text) return '';
      return text
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br>');
    }

    // --- System Prompt Builder ---
    async function buildSystemPrompt() {
      const { repo } = getRepoParts();
      let prompt = `You are an AI coding assistant for a MUD (Multi-User Dungeon) area editor.
You are helping a builder work on the area "${repo}".
You have tools to read, write, create, and delete files in the workspace, manage git, and test changes in-game.

When editing files, always read them first to understand the current content before writing.
After making changes, use git_commit to save your work and trigger a live area reload.
You can test your changes in-game using play_command.
`;

      let fileList = null;
      try {
        fileList = await fetch(`/api/editor/files?repo=${repo}`).then(r => r.json());
        prompt += `\n## Files in workspace\n${fileList.files.map(f => `- ${f}`).join('\n')}\n`;
      } catch (e) {}

      if (currentFile) {
        prompt += `\n## Currently open file\n${currentFile}\n`;
      }

      // Load agents.md (platform API reference) if it exists
      if (fileList && fileList.files.some(f => f === 'agents.md')) {
        try {
          const agentsData = await fetch(`/api/editor/files/${encodeURIComponent('agents.md')}?repo=${repo}`).then(r => r.json());
          prompt += `\n## Platform API Reference\n${agentsData.content}\n`;
        } catch (e) {}
      }

      for (const skill of allSkills) {
        if (skill.source !== 'builder') {
          prompt += `\n## Skill: ${skill.name}\n${skill.content || skill.description}\n`;
        }
      }

      if (fileList) {
        const skillFiles = fileList.files.filter(f => f.startsWith('.skills/') && f.endsWith('.md'));
        for (const sf of skillFiles) {
          try {
            const data = await fetch(`/api/editor/files/${encodeURIComponent(sf)}?repo=${repo}`).then(r => r.json());
            prompt += `\n## Builder Skill: ${sf}\n${data.content}\n`;
          } catch (e) {}
        }
      }

      return prompt;
    }


<div class="container mt-5" style="max-width: 400px;">
  <h1 class="mb-4">New Character</h1>
  <% if error %>
    <div class="alert alert-danger"><%= error %></div>
  <% end %>
  <form method="post" action="/account/characters/new">
    <div class="mb-3">
      <label class="form-label">Character Name</label>
      <input name="name" class="form-control" required>
    </div>
    <button type="submit" class="btn btn-primary w-100">Create Character</button>
  </form>
  <p class="mt-3">
    <a href="/account/characters" class="text-info">Back to Characters</a>
  </p>
</div>
